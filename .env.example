# ==========================================
# INFRASTRUCTURE SETTINGS
# ==========================================

# PostgreSQL Database
POSTGRES_USER=your_db_user_here
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=imdb_ai_db
POSTGRES_HOST=imdb_postgres
POSTGRES_PORT=5432

# Redis Message Broker
REDIS_HOST=imdb_redis
REDIS_PORT=6379
# Stream and consumer group settings for movies and AI tasks
MOVIES_STREAM_NAME=movies_stream
MOVIES_CONSUMER_GROUP=imdb_worker
MOVIES_CONSUMER_NAME=imdb-worker-1
AI_STREAM_NAME=ai_stream
AI_CONSUMER_GROUP=ai_worker
AI_CONSUMER_NAME=ai-worker-1

# ==========================================
# LOCAL AI (OLLAMA) SETTINGS
# ==========================================

# Use http://host.docker.internal:11434/api/generate if Ollama is running on the host machine
LLM_API_URL=http://host.docker.internal:11434/api/generate

# Specify your downloaded model (e.g., gemma4:e4b, llama3, phi3)
LLM_MODEL_NAME=gemma4:e4b

# Maximum time to wait for a single local LLM response, in seconds
LLM_TIMEOUT_SECONDS=600
