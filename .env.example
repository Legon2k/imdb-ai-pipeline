# ==========================================
# INFRASTRUCTURE SETTINGS
# ==========================================

# Logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ---- PostgreSQL Database
#
# Credentials for database authentication
POSTGRES_USER=your_db_user_here
# WARNING: Keep this secure! Use strong passwords in production
POSTGRES_PASSWORD=your_secure_password_here
# Database name and connection details
POSTGRES_DB=imdb_ai_db
POSTGRES_PORT=5432
# POSTGRES_HOST: network hostname inside Docker (for Docker containers use 'imdb_postgres', for local use 'localhost')
POSTGRES_HOST=imdb_postgres

# ---- Redis Message Broker
#
# Redis port (default: 6379, change only if you have port conflicts)
REDIS_PORT=6379
# REDIS_HOST: network hostname inside Docker (for Docker containers use 'imdb_redis', for local use 'localhost')
REDIS_HOST=imdb_redis

# ==========================================
# MICROSERVICES SETTINGS
# ==========================================

# ---- API Gateway
#
# Port to expose the FastAPI Swagger UI and endpoints
API_PORT=8000

# ---- Movie Processing Stream Settings
#
# Name of the Redis stream for movie data
MOVIES_STREAM_NAME=movies_stream
# Max number of messages to keep in stream (0 = unlimited, use ~1000 for production)
MOVIES_STREAM_MAXLEN=1000
# Consumer group for distributed movie processing
MOVIES_CONSUMER_GROUP=imdb_worker
# Unique consumer name within the group (change for multiple instances)
MOVIES_CONSUMER_NAME=imdb-worker-1

# ---- AI Processing Stream Settings
#
# Name of the Redis stream for AI tasks
AI_STREAM_NAME=ai_stream
# Max number of messages to keep in stream (0 = unlimited, use ~1000 for production)
AI_STREAM_MAXLEN=1000
# Consumer group for AI workers
AI_CONSUMER_GROUP=ai_worker
# Unique consumer name within the group (change for multiple instances)
AI_CONSUMER_NAME=ai-worker-1

# ==========================================
# LOCAL AI (OLLAMA) SETTINGS
# ==========================================

# LLM API Endpoint
# For Docker: use http://host.docker.internal:11434/api/generate to reach host machine
# For local dev: use http://localhost:11434/api/generate
# Note: Ensure Ollama is running before starting the AI worker
LLM_API_URL=http://host.docker.internal:11434/api/generate

# Model Selection
# Available models: gemma4:e4b, llama2, phi3, mistral, neural-chat
# Run 'ollama list' to see installed models, 'ollama pull <model>' to download
LLM_MODEL_NAME=gemma4:e4b

# Response Timeout
# Maximum time in seconds to wait for a single LLM response
LLM_TIMEOUT_SECONDS=600

# ==========================================
# UTILITY SERVICES (pgAdmin, Portainer)
# ==========================================

# ---- pgAdmin Credentials
#
# Port to expose pgAdmin Web UI
PGADMIN_PORT=5050
# Initial admin email for pgAdmin web interface
PGADMIN_EMAIL=admin@admin.com
# Initial admin password for pgAdmin web interface
PGADMIN_PASSWORD=admin